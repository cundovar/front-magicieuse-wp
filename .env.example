# Base de l'API WordPress côté client (relative => proxifiée same-origin via next.config rewrites)
NEXT_PUBLIC_WP_API_BASE=/wp-json

# Origine complète du site WordPress (sans slash final).
# Utilisée côté serveur (RSC) pour les fetch SSG/ISR et par next.config pour le proxy.
# Dev: http://localhost/MAGICIEUSE/htdocs — Prod: https://backmagi.varascundo.com
NEXT_PUBLIC_WP_SITE_URL=

# Base du POST du formulaire de contact (laisser vide => proxy same-origin /wp-json)
NEXT_PUBLIC_WP_BASE_URL=

NEXT_PUBLIC_SLUG_SHOP=boutique
NEXT_PUBLIC_SLUG_PRODUCT=produit
NEXT_PUBLIC_SLUG_COLLECTION=collections
NEXT_PUBLIC_SLUG_CART=panier
NEXT_PUBLIC_SLUG_CHECKOUT=commande
